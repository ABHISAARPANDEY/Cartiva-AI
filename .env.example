# ===========================================
# Cartiva AI - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from your Supabase project settings:
# 1. Go to https://supabase.com and create a new project
# 2. Navigate to Settings > API
# 3. Copy the "Project URL" and "service_role" key

# Your Supabase project URL (e.g., https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service Role Key (NOT the anon key - use service_role for server-side operations)
# WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# OPTIONAL: Database URL (if using Drizzle directly)
# ===========================================
# Format: postgresql://user:password@host:port/database
# You can find this in Supabase > Settings > Database > Connection string
# DATABASE_URL=
